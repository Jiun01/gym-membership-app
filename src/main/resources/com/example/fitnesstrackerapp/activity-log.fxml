<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="anchorPane" prefHeight="600.0" prefWidth="800.0" stylesheets="@FJStyle.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.fitnesstrackerapp.admin.formcontroller.ActivityLogFormController">
   <children>
      <Label fx:id="lb_calendar" layoutX="40.0" layoutY="62.0" prefHeight="94.0" prefWidth="367.0" text="Activity Log">
         <font>
            <Font name="System Bold" size="51.0" />
         </font>
      </Label>
      <DatePicker fx:id="datePicker" layoutX="120.0" layoutY="161.0" />
      <Button fx:id="btn_did" layoutX="238.0" layoutY="360.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="168.0" styleClass="button-blue" text="I did workout" />
      <Button fx:id="btn_skipped" layoutX="28.0" layoutY="360.0" mnemonicParsing="false" prefHeight="45.0" prefWidth="185.0" styleClass="button-blue" text="I skipped workout" />
      <Button fx:id="btn_back" layoutX="173.0" layoutY="433.0" mnemonicParsing="false" styleClass="button-blue" text="BACK" />
      <ImageView fitHeight="259.0" fitWidth="302.0" layoutX="493.0" layoutY="-8.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/undraw_calendar_76t8-removebg-preview.png" />
         </image>
      </ImageView>
      <Label layoutX="519.0" layoutY="221.0" text="Select Workout" />
      <ComboBox fx:id="btn_comboboxselectworkout" layoutX="520.0" layoutY="264.0" prefHeight="25.0" prefWidth="200.0" />
      <Label layoutX="518.0" layoutY="310.0" text="Select Nutrition" />
      <ComboBox fx:id="btn_comboboxselectnutrition" layoutX="520.0" layoutY="357.0" prefHeight="25.0" prefWidth="200.0" />
      <Button fx:id="btn_submit" layoutX="551.0" layoutY="456.0" mnemonicParsing="false" styleClass="button-blue" text="Submit" />
      <Label fx:id="lbl_submissionStatus" layoutX="282.0" layoutY="524.0" prefHeight="62.0" prefWidth="509.0">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label fx:id="lbl_email" layoutX="461.0" layoutY="21.0" prefHeight="62.0" prefWidth="86.0" visible="false">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
